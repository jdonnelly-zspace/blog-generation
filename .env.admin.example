# zSpace Blog Generation — Admin Environment Configuration
#
# --------------------------------------------------------------------
#  THIS FILE IS FOR ADMINS who manage blog API users and policies.
#  Team members should use .env.example instead.
# --------------------------------------------------------------------
#
#  Setup:
#  1. Copy this file to .env:
#       cp .env.admin.example .env
#
#  2. Add your personal token AND your admin tokens below.
#
#  3. Never commit .env to git. It's already in .gitignore.
# --------------------------------------------------------------------

# Active environment: "sandbox" or "production"
DIRECTUS_ENV=sandbox

# ====================================================================
#  SANDBOX (sandbox1.admin.zspace.com)
# ====================================================================

DIRECTUS_URL_SANDBOX=https://sandbox1.admin.zspace.com

# Your personal API token — used by the blog writing workflow.
# Directus tracks your identity via user_created/user_updated.
DIRECTUS_TOKEN_SANDBOX=

# Your admin token — used ONLY by setup_roles.js to create/manage
# API users, roles, and policies. This is your personal Directus admin
# account's static token (Settings -> Users -> Your user -> Token).
# Not used by the blog writing workflow.
DIRECTUS_ADMIN_TOKEN_SANDBOX=

# ====================================================================
#  PRODUCTION (admin.zspace.com)
# ====================================================================

DIRECTUS_URL_PRODUCTION=https://admin.zspace.com

# Your personal API token for production.
DIRECTUS_TOKEN_PRODUCTION=

# Your admin token for production.
DIRECTUS_ADMIN_TOKEN_PRODUCTION=

# ====================================================================
#  ADDITIONAL ENVIRONMENTS
# ====================================================================
# Add more by following the same pattern:
#   DIRECTUS_URL_STAGING=https://staging.admin.zspace.com
#   DIRECTUS_TOKEN_STAGING=
#   DIRECTUS_ADMIN_TOKEN_STAGING=

# zSpace Blog Generation — Environment Configuration
#
# --------------------------------------------------------------------
#  SETUP
# --------------------------------------------------------------------
#  1. Copy this file to .env:
#       cp .env.example .env
#
#  2. Paste the personal API token JP Donnelly sent you on the
#     DIRECTUS_TOKEN_PRODUCTION line below. That's it — no other edits.
#
#  3. Never commit .env to git. It's already in .gitignore.
# --------------------------------------------------------------------
#
#  Each team member has their own personal Directus API token.
#  Your token carries the Blog Writer policy (create/update on mkt_blog
#  and the category junction table). Directus tracks your identity via
#  user_created/user_updated audit fields.
#
#  See guidelines/api-users-and-tokens.md for details.
# --------------------------------------------------------------------

# Active environment — writers stay on production.
DIRECTUS_ENV=production

# --------------------------------------------------------------------
#  PRODUCTION (admin.zspace.com)
# --------------------------------------------------------------------

DIRECTUS_URL_PRODUCTION=https://admin.zspace.com

# Blog writer token (yourname+blog-generation@zspace.com)
DIRECTUS_TOKEN_PRODUCTION=

# --------------------------------------------------------------------
#  ADMIN?
# --------------------------------------------------------------------
# If you manage API users and policies (creating writer accounts,
# rotating tokens, testing tone/style changes in sandbox), use
# .env.admin.example instead. It includes the sandbox environment
# and admin token fields for setup_roles.js.

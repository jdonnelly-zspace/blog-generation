# zSpace Blog Generation — Environment Configuration
#
# --------------------------------------------------------------------
#  SETUP
# --------------------------------------------------------------------
#  1. Copy this file to .env:
#       cp .env.example .env
#
#  2. Set your active environment (start with sandbox):
#       DIRECTUS_ENV=sandbox
#
#  3. Add your personal API token below.
#     Ask JP Donnelly (jdonnelly@zspace.com) to create your account,
#     or if you have admin access:
#       node scripts/setup_roles.js --add-user YOUR_EMAIL --policies blog
#
#  4. Never commit .env to git. It's already in .gitignore.
# --------------------------------------------------------------------
#
#  Each team member has their own personal Directus API token.
#  Your token carries the Blog Writer policy (create/update on mkt_blog
#  and the category junction table). Directus tracks your identity via
#  user_created/user_updated audit fields.
#
#  See guidelines/api-users-and-tokens.md for details.
# --------------------------------------------------------------------

# Active environment: set to "sandbox" or "production"
# Start with "sandbox" for your first blog.
DIRECTUS_ENV=sandbox

# --------------------------------------------------------------------
#  SANDBOX (sandbox1.admin.zspace.com)
# --------------------------------------------------------------------

DIRECTUS_URL_SANDBOX=https://sandbox1.admin.zspace.com

# Your personal API token for sandbox.
DIRECTUS_TOKEN_SANDBOX=

# --------------------------------------------------------------------
#  PRODUCTION (admin.zspace.com)
# --------------------------------------------------------------------

DIRECTUS_URL_PRODUCTION=https://admin.zspace.com

# Your personal API token for production.
DIRECTUS_TOKEN_PRODUCTION=

# --------------------------------------------------------------------
#  ADDITIONAL ENVIRONMENTS
# --------------------------------------------------------------------
# Add more by following the same pattern:
#   DIRECTUS_URL_STAGING=https://staging.admin.zspace.com
#   DIRECTUS_TOKEN_STAGING=

# --------------------------------------------------------------------
#  ADMIN?
# --------------------------------------------------------------------
# If you manage API users and policies, use .env.admin.example instead.
# It includes admin token fields for setup_roles.js.
